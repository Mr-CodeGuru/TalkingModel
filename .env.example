# =============================================================================
#  TalkingModel — Environment Configuration
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored and stays local only.
# =============================================================================

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Repository where model files are stored
HF_REPO_ID=MrDevCoder01/TalkingModel

# Only required if the HF repo is private/gated. Leave blank for public repos.
HF_TOKEN=

# ── Model Defaults ───────────────────────────────────────────────────────────
# Filename of the default GGUF LLM model (must exist in HF repo)
DEFAULT_LLM_MODEL=TM-1B-Q80.gguf

# Vosk model variant: "small" (~40 MB) or "large" (~2.7 GB)
DEFAULT_VOSK_MODEL=small

# ── Local Paths (relative to project root — usually no need to change) ────────
MODELS_DIR=./models
LOG_DIR=./logs
